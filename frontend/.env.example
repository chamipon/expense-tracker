# Optional: call the API from the browser at this origin (requires CORS on Express).
# Leave unset to use same-origin /api (rewritten to Express — see next.config.ts).
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Express base URL for the /api rewrite and for server-side fetch (RSC, Server Actions).
# API_SERVER_ORIGIN=http://127.0.0.1:3001
